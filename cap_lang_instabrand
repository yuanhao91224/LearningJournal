        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%minyak kayu putih bayi%'        THEN 'Minyak Kayu Putih Bayi'
