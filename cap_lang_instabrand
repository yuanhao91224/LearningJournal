        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%minyak ekaliptus aromatherapy%' THEN 'Aromatherapy'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%minyak kayu putih bayi%'        THEN 'Minyak Kayu Putih'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%minyak kayu putih%'               THEN 'Minyak Kayu Putih'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%minyak angin lang%'               THEN 'Medicated oil'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%disinfectant%'                    THEN 'Disinfectant'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%inhaler lang%'                    THEN 'Inhaler Lang'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%balsem aktiv%'                    THEN 'Others'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%balsem lang%'                     THEN 'Balm'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%telon lang%'                      THEN 'Telon Lang'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%green oil%'                       THEN 'Medicated oil'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%gandapura%'                       THEN 'Others'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%sitronela%'                       THEN 'Others'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%sloan%'                           THEN 'Others'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%ambonia%'                         THEN 'Minyak Kayu Putih'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%purasil%'                         THEN 'Others'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%vfresh%'                          THEN 'VFresh'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%geliga%'                          THEN 'Geliga'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%norit%'                           THEN 'Others'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%ifree%'                           THEN 'Others'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%mamo%'                            THEN 'Medicated oil'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%gpu%'                             THEN 'GPU'
        ELSE NULL
    END AS brand_group,
    -- sub_brand: 同样按关键词长度从长到短匹配
    CASE
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%minyak ekaliptus aromatherapy%' THEN 'Minyak Ekaliptus Aromatherapy'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%minyak kayu putih bayi%'        THEN 'Minyak Kayu Putih Bayi'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%minyak kayu putih%'               THEN 'Minyak Kayu Putih'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%minyak angin lang%'               THEN 'Minyak Angin Lang'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%disinfectant%'                    THEN 'Disinfectant'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%inhaler lang%'                    THEN 'Inhaler Lang'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%balsem aktiv%'                    THEN 'Balsem Aktiv'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%balsem lang%'                     THEN 'Balsem Lang'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%telon lang%'                      THEN 'Telon Lang'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%green oil%'                       THEN 'Green Oil'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%gandapura%'                       THEN 'Gandapura'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%sitronela%'                       THEN 'Sitronela'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%sloan%'                           THEN 'Sloan''s'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%ambonia%'                         THEN 'Ambonia'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%purasil%'                         THEN 'Purasil'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%vfresh%'                          THEN 'VFresh'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%geliga%'                          THEN 'Geliga'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%norit%'                           THEN 'Norit'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%ifree%'                           THEN 'iFree'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%mamo%'                            THEN 'MAMO'
        WHEN LOWER(COALESCE(NULLIF(bn.product_name, ''), NULLIF(e.mapped_product_name, ''), e.product_name)) LIKE '%gpu%'                             THEN 'GPU'
        ELSE NULL
    END AS sub_brand,
    MAX(e.spu_qty) AS spu_qty,
    SUM(e.spu_qty * e.unit_qty) AS sku_qty
FROM brand_expanded e
LEFT JOIN brand_name_map bn
  ON TRIM(e.brand_code) = bn.brand_code
LEFT JOIN sci_cdm.dws_trd_sea_order_area po
  ON e.order_no = po.order_no
GROUP BY
    e.stat_date,
    e.platform,
    e.store_name,
    e.store_code,
    e.brand,
    e.country,
    e.order_no,
    e.order_status,
